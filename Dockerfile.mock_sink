FROM python:3.12-slim

WORKDIR /app

# Install minimal dependencies for the mock sink
RUN pip install --no-cache-dir fastapi uvicorn[standard] httpx

# Copy only what's needed for the mock sink
COPY tests/load/mock_sink.py /app/tests/load/mock_sink.py

# Expose port
EXPOSE 8080

# Healthcheck dependency
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Run the app
CMD ["uvicorn", "tests.load.mock_sink:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "2"]